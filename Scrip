-- ==================== LÓGICA ====================
task.spawn(function()
    while true do
        task.wait(0.5)
        if isDupeOn then
            local coreGui = player:FindFirstChild("PlayerGui")
            if coreGui then
                for _, node in pairs(coreGui:GetDescendants()) do
                    if node:IsA("TextLabel") and string.find(node.Text, "x") then
                        local currentVal = tonumber(string.match(node.Text, "%d+"))
                        if currentVal then
                            node.Text = "x" .. (currentVal + incrementValue)
                        end
                    end
                end
            end
        end
    end
end)
