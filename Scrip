local incrementValue = 1

-- ==================== FUNÇÃO DE FORMATAÇÃO ====================
local function formatNumber(n)
    if n >= 1000000 then
        return string.format("%.1fM", n / 1000000):gsub("%.0", "")
    elseif n >= 1000 then
        return string.format("%.0fk", n / 1000)
    else
        return tostring(n)
    end
end

