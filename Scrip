-- ==================== LÓGICA DE DUPLICAÇÃO ====================
task.spawn(function()
    while true do
        task.wait(0.5)
        if isDupeOn then
            -- Busca em todo o PlayerGui
            for _, node in pairs(player.PlayerGui:GetDescendants()) do
                if node:IsA("TextLabel") then
                    local rawText = node.Text:gsub("[x, ]", "") -- Remove 'x', espaços e vírgulas
                    local currentVal = 0
                    
                    if rawText:find("k") then currentVal = tonumber(rawText:gsub("k", "")) * 1000
                    elseif rawText:find("M") then currentVal = tonumber(rawText:gsub("M", "")) * 1000000
                    else currentVal = tonumber(rawText) end
                    
                    if currentVal then
                        node.Text = "x" .. formatNumber(currentVal + incrementValue)
                    end
                end
            end
        end
    end
end)
